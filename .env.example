# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/meta_crm
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meta_crm
DB_USER=postgres
DB_PASSWORD=password

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# AI Modules - OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# AI Modules - Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# AI Modules - Google
GOOGLE_API_KEY=

# AI Modules - Azure
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Meta Business
META_API_VERSION=v18.0
META_APP_ID=
META_APP_SECRET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@metcrm.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
