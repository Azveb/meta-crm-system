{
  "name": "meta-crm-system",
  "version": "1.0.0",
  "description": "Complete Meta Business CRM with AI Communication Center",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "db:init": "psql -U postgres -f database/schema.sql",
    "db:drop": "psql -U postgres -c \"DROP DATABASE IF EXISTS meta_crm;\"",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "axios": "^1.6.2",
    "openai": "^4.24.1",
    "anthropic": "^0.9.1",
    "@google-cloud/language": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "nodemailer": "^6.9.7",
    "bull": "^4.12.2",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "i18next": "^23.7.6",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0"
  }
}
